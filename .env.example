# ─────────────────────────────────────────────────────────────
#   InboxDTE v5 — Variables de Entorno
#   Copia este archivo como .env para desarrollo local
#   En Render.com configura estas variables en el dashboard
#   NUNCA subas el archivo .env a un repositorio
# ─────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-algo-muy-seguro-2024
FLASK_DEBUG=true
PORT=5000

# ── Base de datos ──────────────────────────────────────────
# Local: dejar en blanco o apuntar a SQLite
DATABASE=data/app.db
# Producción (Render la pone automáticamente):
# DATABASE_URL=postgresql://usuario:password@host:5432/inboxdte

# ── Archivos descargados ───────────────────────────────────
DOWNLOAD_FOLDER=downloads
# En Render usar: /tmp/downloads  (ephemeral storage)

# ── Cifrado de contraseñas de aplicación ──────────────────
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Scheduler automático ───────────────────────────────────
# 0 = desactivado, 30 = revisar cada 30 minutos
AUTO_CHECK_INTERVAL=0
